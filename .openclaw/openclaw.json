{
  "agents": {
    "defaults": {
      "model": {
        "primary": "zai/glm-5.1"
      },
      "sandbox": {
        "mode": "off"
      },
      "workspace": "/home/node/.openclaw/workspace",
      "heartbeat": {
        "every": "0m",
        "target": "none",
        "prompt": "Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK."
      }
    },
    "list": [
      {
        "id": "main"
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ]
    }
  },
  "tools": {
    "profile": "full",
    "fs": {
      "workspaceOnly": false
    },
    "exec": {
      "applyPatch": {
        "workspaceOnly": false
      }
    }
  },
  "plugins": {
    "entries": {
      "ollama": {
        "enabled": false
      },
      "openrouter": {
        "enabled": false
      },
      "zai": {
        "enabled": true
      }
    }
  }
}
