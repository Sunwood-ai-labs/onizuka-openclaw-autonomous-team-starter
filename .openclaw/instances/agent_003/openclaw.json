{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "zai/glm-5.1",
        "fallbacks": [
          "zai/glm-5-turbo",
          "zai/glm-5",
          "zai/glm-4.7"
        ]
      },
      "sandbox": {
        "mode": "off"
      },
      "heartbeat": {
        "every": "0m",
        "target": "none",
        "prompt": "Read HEARTBEAT.md if it exists (workspace context) and treat it as an action checklist. Follow it strictly. Do not infer or repeat old tasks from prior chats. If the workspace instructions allow posting, perform exactly one Mattermost action in this heartbeat. Only reply HEARTBEAT_OK when rate-limited, blocked by an API error, or no valid posting target exists.",
        "model": "zai/glm-5.1",
        "lightContext": true,
        "isolatedSession": true
      }
    },
    "list": [
      {
        "id": "main",
        "heartbeat": {
          "every": "4m",
          "lightContext": true,
          "isolatedSession": true,
          "target": "none",
          "prompt": "Read HEARTBEAT.md if it exists (workspace context) and treat it as an action checklist. Follow it strictly. Do not infer or repeat old tasks from prior chats. If the workspace instructions allow posting, perform exactly one Mattermost action in this heartbeat. Only reply HEARTBEAT_OK when rate-limited, blocked by an API error, or no valid posting target exists.",
          "model": "zai/glm-5.1"
        }
      },
      {
        "id": "autochat-noctis",
        "name": "autochat-noctis",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/autochat-noctis/agent",
        "model": "zai/glm-5.1"
      },
      {
        "id": "discuss-noctis",
        "name": "discuss-noctis",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/discuss-noctis/agent",
        "model": "zai/glm-5.1"
      },
      {
        "id": "mattermost-lounge-saku",
        "name": "mattermost-lounge-saku",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/mattermost-lounge-saku/agent",
        "model": "zai/glm-5.1"
      },
      {
        "id": "persona-verify-saku",
        "name": "persona-verify-saku",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/persona-verify-saku/agent",
        "model": "zai/glm-5.1"
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18793",
        "http://localhost:18793"
      ]
    }
  },
  "tools": {
    "profile": "full",
    "fs": {
      "workspaceOnly": false
    },
    "exec": {
      "applyPatch": {
        "workspaceOnly": false
      }
    }
  },
  "plugins": {
    "entries": {
      "ollama": {
        "enabled": false
      },
      "mattermost": {
        "enabled": true
      },
      "openrouter": {
        "enabled": false
      },
      "zai": {
        "enabled": true
      }
    }
  },
  "channels": {
    "mattermost": {
      "enabled": true,
      "botToken": "j4hm9my3xjrfzr8bucbfhc5qhy",
      "baseUrl": "http://mattermost:8065",
      "chatmode": "oncall",
      "dmPolicy": "open",
      "groupPolicy": "open",
      "replyToMode": "all",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "network": {
        "dangerouslyAllowPrivateNetwork": true
      }
    }
  },
  "auth": {
    "cooldowns": {
      "rateLimitedProfileRotations": 10
    }
  }
